# Telegram API credentials — https://my.telegram.org/auth
TELEGRAM_API_ID=your_app_id
TELEGRAM_API_HASH=your_hash

# Postgres password used by docker-compose (user/db are both "telegram")
POSTGRES_PASSWORD=change_me

# Image understanding (optional) — leave XAI_API_KEY empty to disable.
# Images are analyzed by xAI's vision API; only the sha256 hash and the
# generated description are stored, never the image bytes.
XAI_API_KEY=
#XAI_MODEL=grok-4.3
#MAX_IMAGE_BYTES=10485760  # skip images larger than 10 MiB

# Optional tuning
#DIALOG_LIMIT=200          # dialogs covered by the full sync at startup
#INITIAL_SYNC_LIMIT=500    # history depth for never-seen chats
#RECONCILE_INTERVAL=60     # seconds between self-heal passes
#LOG_LEVEL=INFO
